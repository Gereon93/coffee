@page "/coffeeAi"
@using Blazorise
@using Blazorise.Charts
@using Blazorise.Icons.FontAwesome
@using CoffeeWeb.Services
@using System.Globalization

@inject NivonaStatisticsService nivonaStatsService

<PageTitle>Coffee-AI-Services</PageTitle>

<h1 class="text-center mt-5">Coffee-AI Statistic Services</h1>

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6">
            <h2>Coffee-AI Statistic Forecast</h2>
            <div class="form-group">
                <Label>Enter date for Forecast (yyyy-MM-dd)</Label>
                <InputText class="form-control" @bind-Value="dateForForecast" />
            </div>
            <Button Color="Color.Primary" @onclick="HandleButtonClickAsync" class="mt-2">Predict</Button>
            <p class="mt-3 alert alert-info">@outputPrediction</p>
        </div>

        <div class="col-md-6">
            <h2>Coffee-AI Statistic Image Parser</h2>
            <Label>Insert image of statistics page in Nivona App here</Label>
            <InputFile OnChange="HandleFileUpload" class="form-control-file" />
        </div>
    </div>
</div>

@code {
    private string dateForForecast = DateTime.Now.ToString("yyyy-MM-dd");
    private string outputPrediction = string.Empty;

    private async Task HandleButtonClickAsync()
    {
        outputPrediction = string.Empty;
        DateTime forecastDate = DateTime.ParseExact(dateForForecast, "yyyy-MM-dd", CultureInfo.InvariantCulture);
        var result = await nivonaStatsService.GetForecastAsync(forecastDate);
        outputPrediction = result;
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        var stream = file.OpenReadStream();
        var fileParameter = new FileParameter(stream, file.Name, file.ContentType);
        await nivonaStatsService.UploadImageForStatsAsync(fileParameter);
    }
}
