@page "/coffeePackagesSite"
@using CoffeeWeb.Services
@inject CoffeeService coffeeService

<PageTitle>Kaffepackungen-Statistik</PageTitle>

<h1>Verbrauchte Kaffeepackung</h1>

@if (coffeePackages == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Kaffeename</th>
                <th>Anzahl</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var package in coffeePackages)
            {
                <tr>
                    <td>@package.DateTimeStamp.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@package.CoffeeName</td>
                    <td>@package.Count</td>
                </tr>
            }
        </tbody>
    </table>
    <div>
        <h3>Hinzufügen einer neuen Kaffeepackung</h3>
        <form>
            <label for="coffeeName">Kaffeename:</label>
            <input type="text" id="coffeeName" name="coffeeName" @bind="@CoffeeNameToAdd" required>

            <label for="count">Anzahl:</label>
            <input type="number" id="count" name="count" @bind="@CountToAdd" required>

            <button class="btn btn-primary" @onclick="AddNewPackage">Eintragen</button>
        </form>
    </div>
}

@code {
    private List<CoffeePackages>? coffeePackages;
    private string CoffeeNameToAdd { get; set; } = "Ettli Reichentaler Kaffee";
    private int CountToAdd { get; set; } = 1;

    protected override async Task OnInitializedAsync()
    {
        coffeePackages = await coffeeService.GetStatisticsAsync();
        coffeePackages = coffeePackages.OrderBy(x => x.DateTimeStamp).ToList();

    }

    private async void AddNewPackage()
    {
        var newPackage = new CoffeePackages{
            DateTimeStamp = DateTimeOffset.UtcNow,
                CoffeeName = CoffeeNameToAdd,
                Count = CountToAdd
            };
        await coffeeService.AddCoffeePackageAsync(newPackage);
    }
}
